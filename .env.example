# ─────────────────────────────────────────────────────────────────────────
# Concordia College — Environment Variables
#
# Copy this file to `.env` and fill in real values. NEVER commit the real
# `.env` file (it's gitignored). For Vercel, set these in the project's
# Environment Variables settings.
# ─────────────────────────────────────────────────────────────────────────

# ── Database (Turso / libSQL) ─────────────────────────────────────────────
# Production: get these from https://turso.tech → your database → Settings
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Local dev fallback (only used if TURSO_AUTH_TOKEN is unset)
# Leave empty to use the default local SQLite file at ./db/custom.db
DATABASE_URL=

# ── Seed passwords ────────────────────────────────────────────────────────
# Set ALL of these to strong, unique passwords in production.
# If unset, a development fallback is used (local dev only — never prod).
SEED_PASSWORD_SUPER_ADMIN=
SEED_PASSWORD_ADMIN=
SEED_PASSWORD_ADMISSIONS=
SEED_PASSWORD_ACCOUNTANT=
SEED_PASSWORD_ACADEMIC=

# ── AI skills (optional — only if using z-ai-web-dev-sdk features) ────────
# These are server-only. Never expose in client code.
ZAI_API_KEY=
